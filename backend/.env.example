DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vero"
JWT_SECRET="change-me"
GEMINI_API_KEY="your-gemini-api-key"

# Paystack. Secret key is server-side only — never ship it to a frontend.
# NOTE: /bank/resolve (account name enquiry) requires a LIVE secret key on an
# activated Paystack business. Test keys can list banks but cannot resolve names.
PAYSTACK_SECRET_KEY="sk_test_or_live_..."
PAYSTACK_PUBLIC_KEY="pk_test_or_live_..."

PORT=8080
